[
  {
    "name": "rule34",
    "enabled": true,
    "match": ["*://rule34.xxx/*", "*://*.rule34.xxx/*"],
    "script": "rule34-gallery.js",
    "grants": ["GM_addStyle", "GM_xmlhttpRequest"]
  },
  {
    "name": "shopee-checkin",
    "enabled": true,
    "match": ["https://shopee.tw/*"],
    "script": "shopee-checkin.js",
    "grants": ["GM_setValue", "GM_getValue", "GM_deleteValue"]
  },
  {
    "name": "shopee-debug",
    "enabled": true,
    "match": ["https://shopee.tw/*"],
    "script": "shopee-debug.js",
    "grants": []
  },
  {
    "name": "exhentai-layout",
    "enabled": false,
    "match": ["https://exhentai.org/g/*", "https://e-hentai.org/g/*"],
    "script": "exhentai-layout.js",
    "grants": ["GM_addStyle"]
  },
  {
    "name": "mhnow-bypass",
    "enabled": false,
    "match": ["https://mhnow.me/*"],
    "script": "mhnow-bypass.js",
    "grants": []
  },
  {
    "name": "blood-questionnaire",
    "enabled": false,
    "match": ["https://dh.blood.org.tw/donor/questionnaire.htm*"],
    "script": "blood-questionnaire.js",
    "grants": []
  },
  {
    "name": "exhentai-autologin",
    "enabled": false,
    "match": ["https://exhentai.org/*", "https://e-hentai.org/*"],
    "script": "exhentai-autologin.js",
    "grants": ["GM_xmlhttpRequest", "GM_setValue", "GM_getValue"]
  },
  {
    "name": "hanime-download",
    "enabled": true,
    "match": ["*://hanime1.me/*"],
    "script": "hanime-downloader.js",
    "grants": ["GM_addStyle", "GM_xmlhttpRequest"]
  },
  {
    "name": "anime1-infinite-scroll",
    "enabled": true,
    "match": ["*://anime1.me/*", "*://*.v.anime1.me/*"],
    "script": "anime1-infinite-scroll.js",
    "grants": ["GM_addStyle", "GM_xmlhttpRequest", "GM_download", "GM_notification", "GM_openInTab"],
    "connect": ["localhost"],
    "allFrames": true,
    "runAt": "document-end"
  },
  {
    "name": "debug-toolkit",
    "enabled": true,
    "hidden": true,
    "match": ["*://*/*"],
    "script": "debug-toolkit.js",
    "grants": ["GM_addStyle", "GM_xmlhttpRequest"],
    "connect": ["localhost"]
  },
    {
      "name": "nhentai-layout",
      "enabled": true,
      "match": [
        "https://nhentai.net/",
        "https://nhentai.net/g/*",
        "https://nhentai.net/search*",
        "https://nhentai.net/tag/*",
        "https://nhentai.net/artist/*",
        "https://nhentai.net/character/*",
        "https://nhentai.net/parody/*",
        "https://nhentai.net/group/*"
      ],
      "script": "nhentai-dynamic-layout.js",
    "grants": ["GM_addStyle", "GM_xmlhttpRequest", "GM_download"]
    }
]
